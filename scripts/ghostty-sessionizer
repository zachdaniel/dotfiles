#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$({ find ~/dev -mindepth 2 -maxdepth 2 -type d | while read -r dir; do
        for marker in .git mix.exs Cargo.toml package.json go.mod pyproject.toml Gemfile build.zig flake.nix Makefile dune-project .project-root; do
            if [[ -e "$dir/$marker" ]]; then echo "$dir"; break; fi
        done
    done; echo ~/.dotfiles; } | fzf --tiebreak=end)
fi

if [[ -z $selected ]]; then
    exit 0
fi

# Resolve to absolute path
selected=$(cd "$selected" && pwd)
SESSION_FILE="${TMPDIR:-/tmp}/ghostty-sessions"
touch "$SESSION_FILE"

# Look up stored window ID for this project
stored_id=$(grep "^${selected}	" "$SESSION_FILE" | tail -1 | cut -f2)

result="not_found"
if [[ -n "$stored_id" ]]; then
    result=$(osascript <<EOF
tell application "Ghostty"
    repeat with w in every window
        if id of w is "$stored_id" then
            activate window w
            activate
            return "found"
        end if
    end repeat
    return "not_found"
end tell
EOF
)
fi

if [[ "$result" == "not_found" ]]; then
    # Clean stale entry if any
    grep -v "^${selected}	" "$SESSION_FILE" > "${SESSION_FILE}.tmp" 2>/dev/null && mv "${SESSION_FILE}.tmp" "$SESSION_FILE"

    # Capture existing window IDs
    before=$(osascript -e 'tell application "Ghostty" to return id of every window' 2>/dev/null)

    open -na Ghostty.app --args --working-directory="$selected"

    # Wait for the new window to appear and grab its ID
    new_id=""
    for _ in $(seq 1 20); do
        sleep 0.25
        new_id=$(osascript <<INNEREOF
tell application "Ghostty"
    repeat with w in every window
        set wid to id of w
        if "$before" does not contain wid then
            return wid
        end if
    end repeat
    return ""
end tell
INNEREOF
)
        if [[ -n "$new_id" ]]; then break; fi
    done

    # Store the mapping
    echo "${selected}	${new_id}" >> "$SESSION_FILE"
fi
