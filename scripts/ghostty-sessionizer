#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$({ find ~/dev -mindepth 2 -maxdepth 2 -type d | while read -r dir; do
        for marker in .git mix.exs Cargo.toml package.json go.mod pyproject.toml Gemfile build.zig flake.nix Makefile dune-project .project-root; do
            if [[ -e "$dir/$marker" ]]; then echo "$dir"; break; fi
        done
    done; echo ~/.dotfiles; } | fzf --tiebreak=end)
fi

if [[ -z $selected ]]; then
    exit 0
fi

# Resolve to absolute path
selected=$(cd "$selected" && pwd)
SESSION_FILE="${TMPDIR:-/tmp}/ghostty-sessions"
touch "$SESSION_FILE"

# Look up stored window ID for this project
stored_id=$(grep "^${selected}	" "$SESSION_FILE" | tail -1 | cut -f2)

result="not_found"
if [[ -n "$stored_id" ]]; then
    result=$(osascript <<EOF
tell application "Ghostty"
    set allWins to every window
    set targetIdx to -1
    repeat with i from 1 to count of allWins
        if id of (item i of allWins) is "$stored_id" then
            set targetIdx to i
            exit repeat
        end if
    end repeat
end tell

if targetIdx is not -1 then
    tell application "System Events"
        tell process "Ghostty"
            perform action "AXRaise" of window targetIdx
        end tell
    end tell
    tell application "Ghostty" to activate
    return "found"
else
    return "not_found"
end if
EOF
)
fi

if [[ "$result" == "not_found" ]]; then
    # Clean stale entry if any
    grep -v "^${selected}	" "$SESSION_FILE" > "${SESSION_FILE}.tmp" 2>/dev/null && mv "${SESSION_FILE}.tmp" "$SESSION_FILE"

    new_id=$(osascript <<EOF
tell application "Ghostty"
    activate
    set cfg to new surface configuration
    set initial working directory of cfg to "$selected"
    set win to new window with configuration cfg
    return id of win
end tell
EOF
)

    # Store the mapping
    echo "${selected}	${new_id}" >> "$SESSION_FILE"
fi
