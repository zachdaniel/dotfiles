#!/usr/bin/env bash

set -e

PARENT_CMD="$(ps -o comm= -p "$PPID" 2>/dev/null | tr -d ' ')"
case "$PARENT_CMD" in
  *nu|*nushell)
    echo "Error: do not run ./install from nushell — some commands break under nu."
    echo "Run it from bash or zsh instead, e.g.: bash ./install"
    exit 1
    ;;
esac

CONFIG="install.conf.yaml"
DOTBOT_DIR="dotbot"

DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" --plugin-dir dotbot-brewfile -c "${CONFIG}" "${@}"
