# Theme

theme = Catppuccin Mocha

# Darker background than Mocha's default Base (#1e1e2e) — using Mantle
background = 181825

# Transparency
background-opacity = 0.85
background-blur = 15

# Font
font-size = 13
font-thicken = true

# Window
macos-titlebar-style = hidden
macos-option-as-alt = true
window-padding-x = 14
window-padding-y = 10
window-padding-balance = true
window-padding-color = extend
window-save-state = never

# Shell
command = /opt/homebrew/bin/nu
env = LC_ALL=en_US.UTF-8

# Shell integration
shell-integration = detect
term = xterm-256color

# Misc
clipboard-read = allow
clipboard-write = allow
copy-on-select = true
mouse-hide-while-typing = true
unfocused-split-opacity = 0.7
resize-overlay = never
minimum-contrast = 3

# Split navigation (ctrl+shift+hjkl always works, even in TUI apps like Claude Code)
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right
